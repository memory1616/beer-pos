# =============================================================================
# BeerPOS Environment Variables - PRODUCTION (VPS Cloud Server)
# =============================================================================

# Server - Production VPS
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Auth
ADMIN_USER=admin
ADMIN_PASSWORD=Zxcv@1234

# Branding
DISTRIBUTOR_NAME=BeerPOS Cloud

# Domain Configuration - UPDATE THESE with your actual domain or IP
ADMIN_DOMAIN=103.75.183.57
PUBLIC_DOMAIN=103.75.183.57

# =============================================================================
# CLOUD MODE - CRITICAL FOR SYNC
# =============================================================================
# These settings make this server act as a central data hub
# All other devices will sync with this server

IS_CLOUD_SERVER=true
CLOUD_MODE=true
CLOUD_DOMAIN=http://103.75.183.57:3000

# =============================================================================
# JWT Secret - CHANGE THIS IN PRODUCTION
# =============================================================================
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS

# Google Maps API Key
GOOGLE_MAPS_API_KEY=

# GitHub Webhook Secret
GITHUB_WEBHOOK_SECRET=

# OpenAI API Key
OPENAI_API_KEY=

# =============================================================================
# Database (SQLite - leave as is)
# This file contains ALL data - make sure to backup regularly!
# =============================================================================
# DB_PATH=./database.sqlite

# =============================================================================
# APP VERSION - Increment after each deployment to force cache refresh
# =============================================================================
APP_VERSION=2026041501
