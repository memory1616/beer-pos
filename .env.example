# Beer POS Pro - Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ===================
# Server Configuration
# ===================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
TZ=Asia/Ho_Chi_Minh

# ===================
# Application Domains
# ===================
ADMIN_DOMAIN=admin.yourdomain.com
PUBLIC_DOMAIN=yourdomain.com

# ===================
# Authentication
# ===================
# Admin login credentials
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_strong_password

# Session configuration (milliseconds)
# Default: 30 days = 2592000000
SESSION_DURATION_MS=2592000000

# ===================
# Security
# ===================
# Allowed CORS origins (comma-separated)
# Use * for all origins (default for development)
ALLOWED_ORIGINS=*

# Webhook secrets for auto-deploy
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
DEPLOY_WEBHOOK_SECRET=your_deploy_webhook_secret

# ===================
# Business
# ===================
DISTRIBUTOR_NAME=Your Distributor Name

# ===================
# Cloud Sync
# ===================
IS_CLOUD_SERVER=false
CLOUD_MODE=false
CLOUD_DOMAIN=your-cloud-domain.com

# ===================
# Logging
# ===================
LOG_LEVEL=info
