# =============================================================================
# BeerPOS Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Auth
ADMIN_USER=admin
ADMIN_PASSWORD=Zxcv@1234

# Branding
DISTRIBUTOR_NAME=Bia Tươi Gia Huy

# Domain Configuration (IMPORTANT for 2-domain setup)
ADMIN_DOMAIN=admin.biatuoitayninh.store
PUBLIC_DOMAIN=biatuoitayninh.store

# Cloud Mode
IS_CLOUD_SERVER=true
CLOUD_MODE=true
CLOUD_DOMAIN=https://admin.biatuoitayninh.store

# Deployment / Cache Busting
# IMPORTANT: Increment this value after each deployment to force browser cache refresh
# Example: APP_VERSION=2026032902
APP_VERSION=2026032901

# JWT Auth (change this secret!)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS

# GitHub webhook POST https://<domain>/deploy — Secret phải trùng khớp với ô "Secret" trên GitHub
GITHUB_WEBHOOK_SECRET=

# Legacy / Simple webhook: POST /webhook/deploy vớiBearer token hoặc body token
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEPLOY_WEBHOOK_SECRET=c19b1a878fac3759868988c9a4d43e31b685cce1e46c2cde0660608c1637e948

# Database (SQLite — leave as is)
# DB_PATH=./database.sqlite

# Google Maps API Key (for real driving routes)
# Get from: https://console.cloud.google.com/google/maps-apis/
# Enable "Directions API" in Google Cloud Console
GOOGLE_MAPS_API_KEY=
